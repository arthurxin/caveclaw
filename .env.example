# --- CaveClaw AgentCore Configuration ---

# MAX_CONSECUTIVE_FAILURES: 熔断保护阈值
# 当大模型连续调用工具报错、并且自己尝试修复也连续失败达到此次数时，
# 引擎会主动跳出，返回 `human_intervention_required` 事件，防止无限烧 API 费用。
MAX_CONSECUTIVE_FAILURES=5

# MAX_ROUNDS: 单次回合的最大循环轮数
# 限定模型在一次思考任务中，最多允许调用工具返回来回跑多少圈。
# 一旦达到此时，强制中断并请求启动 Phase 3: Consolidation（状态压缩和记忆重置）。
MAX_ROUNDS=20

# -----------------------------------------------------------------------------
# Phase 4: Universal LLM Wrapper Config
# -----------------------------------------------------------------------------

# 标准厂商 API Keys
OPENAI_API_KEY=sk-proj-xxx...
ANTHROPIC_API_KEY=sk-ant-xxx...
GEMINI_API_KEY=AIzaSy...
DEEPSEEK_API_KEY=sk-deepseek-...

# 如果使用中转或代理，可以配置自定义 BASE_URL
# 如果不配置，框架将读取 SDK 默认的官方地址
# OPENAI_BASE_URL=https://api.openai.com/v1
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# GOOGLE_API_KEY 和 GEMINI_API_KEY 两者均可识别，GoogleProvider 优先读前者

# MiniMax Local （本地部署 / 内网代理）
# api 类型设为 minimax-local
MINIMAX_API_KEY=sk-minimax-xxx...     # 如果不需要鉴权可以填 EMPTY
MINIMAX_BASE_URL=http://localhost:8080/v1
